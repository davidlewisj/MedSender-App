{
  "manifest_version": 3,
  "name": "EasyFax v1.3",
  "description": "EasyFax: A MedSender extension for sending and tracking faxes.",
  "version": "1.3.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://api.medsender.com/*",
    "https://*.advancedmd.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.advancedmd.com/*",
        "https://*.advancedmd.com/WebClinical/ChartViewerDetail.aspx*",
        "https://*.advancedmd.com/apps/amds-patient-chart/*",
        "https://*.advancedmd.com/amds/wc/*"
      ],
      "js": [
        "content-advancedmd.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "EasyFax v1.3",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
